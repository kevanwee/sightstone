# ─── DATABASE (Supabase - free tier) ──────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → Database → Connection String (URI)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── AUTH (NextAuth v5) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI (Anthropic Claude - pay-per-use, very cheap) ─────────────────────────
# Get from: https://console.anthropic.com/account/keys
# Free alternative: Use GROQ_API_KEY below (free tier: 14,400 reqs/day)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── STORAGE (Supabase Storage - free tier: 1GB) ─────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
